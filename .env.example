# ── Required ────────────────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 32
GUARDIAN_API_KEY=replace-me-with-a-strong-secret

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite (fine for single-node / dev)
GUARDIAN_DB_URL=sqlite:////app/data/guardian.db

# PostgreSQL (uncomment and use --profile postgres):
# GUARDIAN_DB_URL=postgresql://guardian:changeme@postgres:5432/guardian
# POSTGRES_PASSWORD=changeme

# ── API Server ───────────────────────────────────────────────────────────────
GUARDIAN_HOST=0.0.0.0
GUARDIAN_PORT=8000

# ── NVD Feed (optional — increases rate limit) ───────────────────────────────
# Register free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────────────
GUARDIAN_DEBUG=false
GUARDIAN_SCAN_TIMEOUT=300
GUARDIAN_REPORT_DIR=/app/data/reports
